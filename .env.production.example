# ── QoriCash Web — Variables de Entorno para PRODUCCIÓN ──────────────────────
# Copiar este archivo como referencia al configurar variables en Vercel Dashboard
# Settings → Environment Variables → Production

# ── Backend Flask (PÚBLICO — visible en el browser) ──────────────────────────
# URL base para llamadas cliente → proxy Next.js
NEXT_PUBLIC_API_URL=https://www.qoricash.pe/api/flask

# ── Backend Flask (PRIVADO — solo server-side API routes) ────────────────────
BACKEND_URL=https://app.qoricash.pe

# ── Upstash Redis (noticias + alertas TC) ────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://first-lizard-121914.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token_aqui>

# ── Admin Panel (/admin/noticias) ─────────────────────────────────────────────
ADMIN_SECRET=<contraseña_segura_produccion>

# ── Ticker de mercado ─────────────────────────────────────────────────────────
TICKER_API_KEY=<key_produccion>

# ── Resend (alertas de tipo de cambio por email) ─────────────────────────────
RESEND_API_KEY=<resend_api_key>

# ── Cron secret (compartido entre Flask y qoricashweb) ────────────────────────
CRON_SECRET=<secret_seguro_produccion>

# ── WhatsApp Webhook ──────────────────────────────────────────────────────────
WA_VERIFY_TOKEN=<meta_verify_token>
WA_SHEETS_ID=<google_spreadsheet_id>
GOOGLE_CLIENT_ID=<google_oauth_client_id>
GOOGLE_CLIENT_SECRET=<google_oauth_client_secret>
GOOGLE_REFRESH_TOKEN=<google_oauth_refresh_token>
