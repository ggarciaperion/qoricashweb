* { padding: 0; margin: 0; }
html, body, div, span, a, img, h1, h2, p, ul, li {
    font-family: inherit;
    font-size: 100%;
    line-height: inherit;
    font-weight: normal;
    font-style: normal;
    text-transform: none;
    text-decoration: none;
    list-style: none;
    background: transparent;
    padding: 0;
    margin: 0;
    border: 0;
    outline: 0;
    vertical-align: baseline;
}

.texto > p {text-align: justify;}

body,td,th {
	font-family: "open_sanslight", sans-serif;
	font-size: 14px;
}

.containier{margin: 0 auto;}
a {
	font-family: "open_sanslight", sans-serif;
	font-size: 16px;
	font-weight: bold;
  color:#0064A7;
}
h1,h2,h3,h4,h5,h6 {
	font-family: GothamBold, serif;
}

.arcoiris-head 
{
    width: 80%;
    position: relative;
    margin: 5px 0 0 0;
    padding: 0;
    list-style: none;  
    display: none;
}

.arcoiris-head  > li{
    width: 14.28%;
    padding: 0 !important;
    margin: 0 !important;
    height: 9px;
    float: left;
}
.arcoiris-head  > li:nth-child(1) {
    background: #f0a605 !important;
}
.arcoiris-head  > li:nth-child(2) {
    background: #fd7000 !important;
}
.arcoiris-head  > li:nth-child(3) {
    background: #dd1c5b !important;
}
.arcoiris-head  > li:nth-child(4) {
    background: #aa0e89 !important;
}
.arcoiris-head  > li:nth-child(5) {
    background: #680ea3 !important;
}
.arcoiris-head  > li:nth-child(6) {
    background: #332175 !important;
}
.arcoiris-head  > li:nth-child(7) {
    background: #1387c2 !important;
}

.arcoiris{
    width: 100%;
    position: relative;
    margin: 5px 0 0 0;
    padding: 0;
    list-style: none;   
    
}
.arcoiris > li{
    width: 14.28%;
    padding: 0 !important;
    margin: 0 !important;
    height: 9px;
    float: left;
}
.arcoiris > li:nth-child(1) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(2) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(3) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(4) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(5) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(6) {
    background: #0064a7 !important;
}
.arcoiris > li:nth-child(7) {
    background: #0064a7 !important;
}
footer{background-color: #0064a7; width: 100%; z-index: 3; color: #FFFFFF; padding: 15px 0; position: absolute; bottom: 0; min-height: 40px;}

.left{float: left;}
.right{float: right;}
.align_left{text-align: left;}
.align_right{text-align: right;}
.align_center{text-align: center;}  
.texto{margin:0 15px;}      
img {height: auto; max-width: 120px;margin-bottom:-3px;}  
td{float:left; position:relative; margin-top:20px}     
 
